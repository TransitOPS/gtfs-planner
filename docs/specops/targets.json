{
  "version": 1,
  "system": {
    "summary": "GTFS Planner is a multi-tenant Phoenix application for managing GTFS transit datasets, including organization-scoped authentication, editable routes and stations, station diagrams, import/export workflows, validation runs, OTP graph and station materialization, companion JSON APIs, and deployment/support tooling.",
    "external_dependencies": [
      "Elixir and Phoenix LiveView",
      "PostgreSQL",
      "Geoapify geocoding API",
      "OpenTripPlanner",
      "OpenStreetMap extracts",
      "SMTP email delivery via Swoosh/gen_smtp",
      "Tailwind CSS and daisyUI",
      "Docker",
      "AWS/OpenTofu infrastructure"
    ]
  },
