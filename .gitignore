# The directory Mix will write compiled artifacts to.
/_build/

# Isolated Mix build dirs (e.g. MIX_BUILD_PATH=_build_test_isolated mix test).
/_build*/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
gtfs_planner-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json
/priv/plts/

# Ignore Phoenix digested static files (files with content hashes)
# Pattern: filename-[32-char-hex-hash].ext
/priv/static/**/*-[a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9].*

# Ignore all gzipped static files
/priv/static/**/*.gz

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Ignore Playwright browser-test artifacts.
/assets/test-results/
/assets/playwright-report/

# Ignore git commit message files
git_commit_message.txt

# Ignore log files
logfile

/test-failures-output.txt

.DS_Store

pathway-studio

priv/static/uploads
priv/otp/*.jar
priv/otp/*.pbf
priv/otp/*.osm
priv/otp/*.osm.pbf

# Infra
.terraform
.envrc
.external_modules
*.tfstate
*.tfstate.backup
infra/modules/rds-database/db_admin/vendor
infra/modules/rds-database/db_admin/.python-version
infra/modules/rds-database/db_admin.zip
# Environment variables
.env

# Spec-driven development artifacts
.specs/
test-results/

# Browser test screenshot output
.artifacts/
